# Copy to .env and fill in. NEVER commit .env.

# --- Follow Up Boss (read + push) --------------------------------------------
FUB_API_KEY=fka_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FUB_X_SYSTEM=DanaCapital-ETL
# Optional until registered with FUB; raises rate limits + identifies the integration.
FUB_X_SYSTEM_KEY=

# --- Niche Data (foreclosure/probate feed) ------------------------------------
# Single token string: <publicId>.<secret>
NICHE_DATA_TOKEN=
# NICHE_BASE_URL=https://customers-api.nichedata.ai

# --- SQL Server warehouse (names shared with GHL_API so code is portable) -----
# Dormant on the Windows box until a SQL Server target exists (see CLAUDE.md §15).
GHL_SQL_SERVER=localhost,1433
GHL_SQL_USER=sa
GHL_SQL_PASSWORD=
GHL_SQL_DATABASE=dcr_warehouse

# --- MCP server (read-only login; see CLAUDE.md §14) --------------------------
# MCP_SQL_USER=dcr_ro
# MCP_SQL_PASSWORD=

# --- Alerts (all optional, best-effort) ---------------------------------------
# Slack/Discord-style incoming webhook for failure + high-value-lead alerts.
# ALERT_WEBHOOK_URL=
# Twilio SMS (trial accounts can only text verified numbers).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=+1XXXXXXXXXX
# ALERT_SMS_TO=+1XXXXXXXXXX

# --- Niche push tuning (defaults shown; see scripts/push_niche_to_fub.py) -----
# NICHE_ALERT_USER=<FUB user name to assign high-value-lead tasks to>
# NICHE_ALERT_MIN_EQUITY=100000

# --- RPRD lead engine inputs (defaults point at the CoWork project) -----------
# RPRD_WAREHOUSE=C:\path\to\RPRD-Leads\warehouse
# RPRD_LEAD_SCORE=C:\path\to\RPRD-Leads\warehouse\lead_score.csv
