# PostgreSQL connection (Linux VPS) — copy the keys you need into the repo .env.
# Used by everything under postgres/ (see postgres/_pg.py). The migration plan is
# in DB_MIGRATION.md.

PG_HOST=100.x.y.z          # the VPS's Tailnet IP (or hostname)
PG_PORT=5432
PG_DATABASE=dcr_warehouse

# Read/write app role (replaces SQL Server `sa`)
PG_USER=dcr
PG_PASSWORD=change-me

# Read-only role (replaces the MCP `dcr_ro` login; used by the MCP server + dashboard)
PG_RO_USER=dcr_ro
PG_RO_PASSWORD=change-me

# Tailscale already encrypts (WireGuard); 'require' adds TLS on top. Use
# 'disable' only if you intentionally run without server TLS.
PGSSLMODE=require

# Optional: full-URL overrides (win over the parts above if set)
# PG_URL=postgresql://dcr:pw@100.x.y.z:5432/dcr_warehouse?sslmode=require
# PG_RO_URL=postgresql://dcr_ro:pw@100.x.y.z:5432/dcr_warehouse?sslmode=require
